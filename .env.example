# Code Review Agent — environment variable reference
# Copy this file to .env in your target project and fill in real values.
# NEVER commit .env with real secrets.

# ── Database (shared team Postgres on Neon) ─────────────────────
# If unset, the app uses the shared Neon cloud DB baked into config.
# Override here to point at your own DB (local dev or another cloud).
# CRA_DATABASE_URL=postgresql://neondb_owner:npg_JmZTG6FwKpE7@ep-jolly-cloud-amn3kbk3.c-5.us-east-1.aws.neon.tech/neondb?sslmode=require

# ── Super Admin credentials ─────────────────────────────────────
# CRA_SUPER_ADMIN_EMAIL=admin@yourcompany.com
# CRA_SUPER_ADMIN_PASSWORD=change-me-strong-password

# AI Provider API keys (set ONE of these — priority: Groq > Gemini > OpenAI > Claude)
GROQ_API_KEY=your_groq_api_key_here
# GEMINI_API_KEY=your_gemini_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: URL of a centralised rule API
REVIEW_RULES_API_URL=https://rules.yourcompany.com/api/v1

# Optional: Bearer token for authenticating with the rules API
REVIEW_RULES_API_TOKEN=your_token_here

# Optional: Power Automate webhook URL for daily report delivery
CRA_FLOW_URL="https://defaultcff20d814abd4f219998f39afd1df6.2a.environment.api.powerplatform.com:443/powerautomate/automations/direct/workflows/243a9a7a866c46dca7f63ba89b2feced/triggers/manual/paths/invoke?api-version=1&sp=%2Ftriggers%2Fmanual%2Frun&sv=1.0&sig=YOxpQhyv1jIB2Cc2UDF7bX4PEXz0BTKb0Nnl2Kw7_RI"
